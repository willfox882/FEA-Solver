## DATA MODELS

### Python (canonical — serialized to/from JSON)

```python
# Node
{
  "id": int,           # 1-based CalculiX node number
  "x": float,          # SI: meters
  "y": float,
  "z": float
}

# Element
{
  "id": int,           # 1-based
  "type": "C3D10",     # 10-node tet (default); also C3D4 allowed
  "nodes": [int, ...]  # node IDs, length matches element type
}

# FaceGroup (CAD face → mesh surface)
{
  "face_id": int,       # OCC/Gmsh face tag
  "element_faces": [[element_id, face_index], ...],  # face_index: 0-3 for tet
  "node_ids": [int, ...]  # all nodes on this face (deduplicated)
}

# Material
{
  "name": str,
  "youngs_modulus": float,  # Pa
  "poissons_ratio": float
}

# BoundaryCondition
{
  "type": "FIXED" | "ROLLER_X" | "ROLLER_Y" | "ROLLER_Z" | "PINNED",
  "face_id": int,
  "node_ids": [int, ...]  # resolved from face_map at BC assignment time
}

# Load (distributed surface traction)
{
  "type": "SURFACE_TRACTION" | "PRESSURE",
  "face_id": int,
  "magnitude": float,   # Pa (pressure) or N/m² (traction)
  "direction": [float, float, float]  # unit vector (global), null for pressure
}

# LocalizedLoad — point load
{
  "type": "POINT_LOAD",
  "face_id": int,          # face where load is applied
  "location": {
    "mode": "NEAREST_NODE" | "PARAMETRIC" | "ABSOLUTE_XYZ",
    "xyz": [float, float, float],   # absolute coords OR resolved coords
    "uv": [float, float]            # parametric [0-1] if mode=PARAMETRIC
  },
  "force": [float, float, float],   # N, global XYZ
  "resolved_node_id": int           # set during INP generation
}

# LocalizedLoad — moment/torque
{
  "type": "MOMENT" | "TORQUE",
  "face_id": int,
  "axis_origin": [float, float, float],
  "axis_direction": [float, float, float],  # unit vector
  "magnitude": float,          # N·m
  "moment_vector": [float, float, float],   # N·m, derived from axis+magnitude
  "node_ids": [int, ...]       # distributed over face nodes as force couple
}

# ResultField
{
  "type": "DISPLACEMENT" | "VONMISES",
  "num_nodes": int,
  "node_ids": [int, ...],
  "values": [float, ...]       # scalar (vonmises) or magnitude of vector
}

# Full results
{
  "displacement_x": ResultField,
  "displacement_y": ResultField,
  "displacement_z": ResultField,
  "displacement_mag": ResultField,
  "vonmises": ResultField
}
```

### C# (mirrors Python models, used in WPF)

```csharp
// MeshData.cs — deserialized from mesh_step.py output
public record Node(int Id, double X, double Y, double Z);
public record Element(int Id, string Type, int[] Nodes);
public record FaceGroup(int FaceId, int[][] ElementFaces, int[] NodeIds);
public record MeshData(Node[] Nodes, Element[] Elements, FaceGroup[] FaceGroups);

// BoundaryCondition.cs
public enum BcType { Fixed, RollerX, RollerY, RollerZ, Pinned }
public record BoundaryCondition(BcType Type, int FaceId, int[] NodeIds);

// Load.cs
public enum LoadType { SurfaceTraction, Pressure, PointLoad, Moment, Torque }
public record Load(LoadType Type, int FaceId, double Magnitude,
                   double[]? Direction, LocalizedLoadData? Localized);

// FEAModel.cs — the full model passed to write_inp.py
public record FEAModel(MeshData Mesh, MaterialModel Material,
                       BoundaryCondition[] BCs, Load[] Loads,
                       string WorkDir);
```

