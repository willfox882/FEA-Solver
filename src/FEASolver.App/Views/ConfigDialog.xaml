<Window x:Class="FEASolver.Views.ConfigDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FEASolver.ViewModels"
        Title="Configuration" Height="340" Width="560"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource PrimaryBrush}">

    <Window.DataContext>
        <vm:ConfigDialogViewModel/>
    </Window.DataContext>

    <StackPanel Margin="16">

        <TextBlock Text="Tool Paths" FontWeight="Bold" Margin="0,0,0,8"
                   Foreground="{StaticResource TextBrush}"/>

        <!-- CalculiX -->
        <Grid Margin="0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="70"/>
            </Grid.ColumnDefinitions>
            <Label Content="CalculiX (ccx.exe)" Grid.Column="0" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Text="{Binding CcxPath, UpdateSourceTrigger=PropertyChanged}"
                     Margin="4,0"/>
            <Button Grid.Column="2" Content="Browse..."
                    Command="{Binding BrowseCcxCommand}"/>
        </Grid>

        <!-- Python -->
        <Grid Margin="0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="70"/>
            </Grid.ColumnDefinitions>
            <Label Content="Python executable" Grid.Column="0" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Text="{Binding PythonPath, UpdateSourceTrigger=PropertyChanged}"
                     Margin="4,0"/>
            <Button Grid.Column="2" Content="Browse..."
                    Command="{Binding BrowsePythonCommand}"/>
        </Grid>

        <!-- Scripts dir -->
        <Grid Margin="0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="70"/>
            </Grid.ColumnDefinitions>
            <Label Content="Scripts dir" Grid.Column="0" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Text="{Binding ScriptsDir, UpdateSourceTrigger=PropertyChanged}"
                     Margin="4,0" IsReadOnly="True"/>
            <Button Grid.Column="2" Content="Browse..."
                    Command="{Binding BrowseScriptsDirCommand}"/>
        </Grid>

        <!-- Workspace root -->
        <Grid Margin="0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="70"/>
            </Grid.ColumnDefinitions>
            <Label Content="Workspace" Grid.Column="0" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Text="{Binding WorkspaceRoot, UpdateSourceTrigger=PropertyChanged}"
                     Margin="4,0"/>
            <Button Grid.Column="2" Content="Browse..."
                    Command="{Binding BrowseWorkspaceCommand}"/>
        </Grid>

        <Separator Margin="0,12"/>

        <!-- Validation status -->
        <Border Background="#22FFFFFF" CornerRadius="4" Padding="8" Margin="0,0,0,12"
                Visibility="{Binding ValidationMessage,
                    Converter={StaticResource NullToVisibilityConverter}}">
            <TextBlock Text="{Binding ValidationMessage}"
                       Foreground="#FF6060"
                       TextWrapping="Wrap"
                       FontFamily="Consolas" FontSize="11"/>
        </Border>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Validate" Command="{Binding ValidateCommand}"
                    Margin="0,0,8,0" Width="80"/>
            <Button Content="Save" Command="{Binding SaveCommand}"
                    IsDefault="True" Width="80" Margin="0,0,8,0"/>
            <Button Content="Cancel" IsCancel="True" Width="80"
                    Background="#555" Click="Cancel_Click"/>
        </StackPanel>

    </StackPanel>
</Window>
