<UserControl x:Class="FEASolver.Views.ViewportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helix="http://helix-toolkit.org/wpf">

    <UserControl.Resources>
        <!-- Compact nav-bar button — light theme with explicit dark text via ControlTemplate.
             Without the ControlTemplate, the global App.xaml TextBlock style (#E0E0E0)
             overrides the Button.Foreground and makes text white-on-white. -->
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Padding"          Value="8,2"/>
            <Setter Property="Margin"           Value="1,1"/>
            <Setter Property="FontSize"         Value="11"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ControlTemplate.Resources>
                            <!-- Override the global light-text TextBlock style locally -->
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#1A1A44"/>
                                <Setter Property="FontSize"   Value="11"/>
                            </Style>
                        </ControlTemplate.Resources>
                        <Border x:Name="bd"
                                Background="#E8E8F0"
                                BorderBrush="#CCCCDD"
                                BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                             VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#D0D0E8"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#8888AA"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity"    Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Navigation toolbar ── -->
        <Border Grid.Row="0"
                Background="#EDEDF4"
                BorderBrush="#D0D0DD"
                BorderThickness="0,0,0,1">
            <DockPanel Margin="6,2">

                <!-- Right: control hints -->
                <TextBlock DockPanel.Dock="Right"
                           Text="L-drag: Rotate   R-drag: Zoom   M-drag: Pan   Scroll: Zoom   Home: Fit   ESC: Deselect"
                           Foreground="#888899"
                           FontSize="10"
                           VerticalAlignment="Center"
                           Margin="8,0,4,0"/>

                <!-- Left: view buttons -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                    <Button x:Name="BtnFit"
                            Content="⌂ Fit"
                            Style="{StaticResource NavBtn}"
                            ToolTip="Fit all geometry to screen (Home)"
                            Click="BtnFit_Click"/>

                    <Rectangle Width="1" Fill="#CCCCDD" Margin="4,2"/>

                    <Button x:Name="BtnIso"
                            Content="Iso"
                            Style="{StaticResource NavBtn}"
                            ToolTip="Isometric view (I)"
                            Click="BtnIso_Click"/>

                    <Button x:Name="BtnFront"
                            Content="Front"
                            Style="{StaticResource NavBtn}"
                            ToolTip="Front view — looking along +Y (F)"
                            Click="BtnFront_Click"/>

                    <Button x:Name="BtnRight"
                            Content="Right"
                            Style="{StaticResource NavBtn}"
                            ToolTip="Right-side view — looking along -X (R)"
                            Click="BtnRight_Click"/>

                    <Button x:Name="BtnTop"
                            Content="Top"
                            Style="{StaticResource NavBtn}"
                            ToolTip="Top view — looking down -Z (T)"
                            Click="BtnTop_Click"/>

                    <Button x:Name="BtnLeft"
                            Content="Left"
                            Style="{StaticResource NavBtn}"
                            ToolTip="Left-side view — looking along +X (L)"
                            Click="BtnLeft_Click"/>

                    <Button x:Name="BtnBack"
                            Content="Back"
                            Style="{StaticResource NavBtn}"
                            ToolTip="Back view — looking along -Y (K)"
                            Click="BtnBack_Click"/>

                    <Button x:Name="BtnBottom"
                            Content="Bottom"
                            Style="{StaticResource NavBtn}"
                            ToolTip="Bottom view — looking up +Z (B)"
                            Click="BtnBottom_Click"/>

                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── 3-D Viewport ── -->
        <helix:HelixViewport3D Grid.Row="1"
                               x:Name="Viewport3D"
                               Background="#F5F5F5"
                               ShowCoordinateSystem="True"
                               ShowFrameRate="False"
                               ZoomExtentsWhenLoaded="False"
                               CameraRotationMode="Trackball"
                               RotateAroundMouseDownPoint="True"
                               ZoomAroundMouseDownPoint="True"
                               InfiniteSpin="False"
                               PreviewMouseLeftButtonDown="Viewport3D_PreviewMouseLeftButtonDown"
                               PreviewMouseMove="Viewport3D_PreviewMouseMove"
                               PreviewMouseLeftButtonUp="Viewport3D_PreviewMouseLeftButtonUp"
                               MouseDoubleClick="Viewport3D_MouseDoubleClick"
                               MouseEnter="Viewport3D_MouseEnter"
                               KeyDown="Viewport3D_KeyDown">

            <!-- Default isometric camera — auto-fit will override this once mesh loads -->
            <helix:HelixViewport3D.DefaultCamera>
                <PerspectiveCamera Position="0.3,0.2,0.25"
                                   LookDirection="-1,-0.7,-0.8"
                                   UpDirection="0,0,1"
                                   FieldOfView="40"/>
            </helix:HelixViewport3D.DefaultCamera>

            <!-- Ambient fill (brighter for white background) -->
            <ModelVisual3D>
                <ModelVisual3D.Content>
                    <AmbientLight Color="#909090"/>
                </ModelVisual3D.Content>
            </ModelVisual3D>

            <!-- Key light (upper-left-front) -->
            <ModelVisual3D>
                <ModelVisual3D.Content>
                    <DirectionalLight Color="#C0C0C8" Direction="-1,-2,-1"/>
                </ModelVisual3D.Content>
            </ModelVisual3D>

            <!-- Fill light (opposite) -->
            <ModelVisual3D>
                <ModelVisual3D.Content>
                    <DirectionalLight Color="#606068" Direction="1,1,1"/>
                </ModelVisual3D.Content>
            </ModelVisual3D>

            <!-- Main mesh — steel-blue tint -->
            <helix:MeshGeometryVisual3D x:Name="MeshVisual"
                                        MeshGeometry="{Binding MeshGeometry}"
                                        Visible="{Binding MeshLoaded}">
                <helix:MeshGeometryVisual3D.Fill>
                    <SolidColorBrush Color="#FF5A8EBA"/>
                </helix:MeshGeometryVisual3D.Fill>
            </helix:MeshGeometryVisual3D>

            <!-- Selected-face highlight — semi-transparent cyan -->
            <helix:MeshGeometryVisual3D x:Name="SelectionVisual"
                                        MeshGeometry="{Binding SelectionGeometry}">
                <helix:MeshGeometryVisual3D.Fill>
                    <SolidColorBrush Color="#BB00DDCC"/>
                </helix:MeshGeometryVisual3D.Fill>
            </helix:MeshGeometryVisual3D>

            <!-- Constraint markers — red crosses at BC face centroids -->
            <helix:MeshGeometryVisual3D x:Name="ConstraintMarkersVisual"
                                        MeshGeometry="{Binding ConstraintMarkersGeometry}">
                <helix:MeshGeometryVisual3D.Fill>
                    <SolidColorBrush Color="#FFDD2222"/>
                </helix:MeshGeometryVisual3D.Fill>
            </helix:MeshGeometryVisual3D>

            <!-- Load arrows — orange-yellow arrows at load face centroids -->
            <helix:MeshGeometryVisual3D x:Name="LoadArrowsVisual"
                                        MeshGeometry="{Binding LoadArrowsGeometry}">
                <helix:MeshGeometryVisual3D.Fill>
                    <SolidColorBrush Color="#FFFF8800"/>
                </helix:MeshGeometryVisual3D.Fill>
            </helix:MeshGeometryVisual3D>

        </helix:HelixViewport3D>

        <!-- Overlay: shown before any mesh is loaded -->
        <TextBlock Grid.Row="1"
                   Text="Import a STEP file to begin"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="16"
                   Foreground="#AAAAAA"
                   IsHitTestVisible="False"
                   Visibility="{Binding MeshLoaded,
                       Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

    </Grid>
</UserControl>
