<UserControl x:Class="FEASolver.Views.ModelTreeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:FEASolver.ViewModels">

    <DockPanel Background="{StaticResource SurfaceBrush}">

        <TextBlock DockPanel.Dock="Top"
                   Text="Model Tree"
                   Padding="8,6"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource TextBrush}"
                   Background="{StaticResource PrimaryBrush}"/>

        <TreeView x:Name="Tree"
                  ItemsSource="{Binding RootNodes}"
                  Background="{StaticResource SurfaceBrush}"
                  BorderThickness="0"
                  SelectedItemChanged="Tree_SelectedItemChanged"
                  KeyDown="Tree_KeyDown">

            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                    <Setter Property="Foreground"   Value="{StaticResource TextBrush}"/>
                    <Setter Property="Background"   Value="Transparent"/>
                    <Setter Property="IsExpanded"   Value="True"/>
                    <Setter Property="Padding"      Value="2,1"/>
                    <Setter Property="ContextMenu">
                        <Setter.Value>
                            <ContextMenu>
                                <MenuItem Header="Delete"
                                          Command="{Binding DataContext.DeleteSelectedCommand,
                                              RelativeSource={RelativeSource AncestorType=TreeView}}"
                                          InputGestureText="Del"/>
                            </ContextMenu>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#333355"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TreeView.ItemContainerStyle>

            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate ItemsSource="{Binding Children}"
                                          DataType="{x:Type vm:ModelTreeNode}">
                    <StackPanel Orientation="Horizontal" Margin="0,1">
                        <TextBlock Text="{Binding Icon}" Margin="0,0,4,0"
                                   Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBlock Text="{Binding Label}"
                                   Foreground="{StaticResource TextBrush}"/>
                    </StackPanel>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>

    </DockPanel>
</UserControl>
