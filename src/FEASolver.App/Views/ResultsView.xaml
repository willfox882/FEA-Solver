<UserControl x:Class="FEASolver.Views.ResultsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helix="http://helix-toolkit.org/wpf"
             xmlns:vm="clr-namespace:FEASolver.ViewModels">

    <UserControl.Resources>
        <!-- Same ControlTemplate-based fix as NavBtn in ViewportView -->
        <Style x:Key="ResNavBtn" TargetType="Button">
            <Setter Property="Padding"          Value="8,2"/>
            <Setter Property="Margin"           Value="1,1"/>
            <Setter Property="FontSize"         Value="11"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ControlTemplate.Resources>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#1A1A44"/>
                                <Setter Property="FontSize"   Value="11"/>
                            </Style>
                        </ControlTemplate.Resources>
                        <Border x:Name="bd"
                                Background="#E8E8F0"
                                BorderBrush="#CCCCDD"
                                BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                             VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#D0D0E8"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#8888AA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- nav toolbar -->
            <RowDefinition Height="*"/>      <!-- 3D viewport -->
            <RowDefinition Height="Auto"/>   <!-- bottom controls -->
        </Grid.RowDefinitions>

        <!-- ── Navigation toolbar ── -->
        <Border Grid.Row="0"
                Background="#EDEDF4"
                BorderBrush="#D0D0DD"
                BorderThickness="0,0,0,1">
            <DockPanel Margin="6,2">
                <TextBlock DockPanel.Dock="Right"
                           Text="Results view — L-drag: Rotate   R-drag: Zoom   Scroll: Zoom   Home: Fit"
                           Foreground="#888899"
                           FontSize="10"
                           VerticalAlignment="Center"
                           Margin="8,0,4,0"/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="ResBtnFit"
                            Content="⌂ Fit"
                            Style="{StaticResource ResNavBtn}"
                            ToolTip="Fit results model to screen"
                            Click="ResBtnFit_Click"/>
                    <Rectangle Width="1" Fill="#CCCCDD" Margin="4,2"/>
                    <Button x:Name="ResBtnIso"
                            Content="Iso"
                            Style="{StaticResource ResNavBtn}"
                            ToolTip="Isometric view"
                            Click="ResBtnIso_Click"/>
                    <Button x:Name="ResBtnFront"
                            Content="Front"
                            Style="{StaticResource ResNavBtn}"
                            ToolTip="Front view — looking along +Y"
                            Click="ResBtnFront_Click"/>
                    <Button x:Name="ResBtnRight"
                            Content="Right"
                            Style="{StaticResource ResNavBtn}"
                            ToolTip="Right-side view — looking along -X"
                            Click="ResBtnRight_Click"/>
                    <Button x:Name="ResBtnTop"
                            Content="Top"
                            Style="{StaticResource ResNavBtn}"
                            ToolTip="Top view — looking down -Z"
                            Click="ResBtnTop_Click"/>
                    <Button x:Name="ResBtnLeft"
                            Content="Left"
                            Style="{StaticResource ResNavBtn}"
                            ToolTip="Left-side view — looking along +X"
                            Click="ResBtnLeft_Click"/>
                    <Button x:Name="ResBtnBack"
                            Content="Back"
                            Style="{StaticResource ResNavBtn}"
                            ToolTip="Back view — looking along -Y"
                            Click="ResBtnBack_Click"/>
                    <Button x:Name="ResBtnBottom"
                            Content="Bottom"
                            Style="{StaticResource ResNavBtn}"
                            ToolTip="Bottom view — looking up +Z"
                            Click="ResBtnBottom_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── 3D Results Viewport ── -->
        <helix:HelixViewport3D x:Name="ResultsViewport"
                               Grid.Row="1"
                               Background="#F5F5F5"
                               ShowCoordinateSystem="True"
                               ZoomExtentsWhenLoaded="True"
                               MouseDown="ResultsViewport_MouseDown">

            <ModelVisual3D>
                <ModelVisual3D.Content>
                    <AmbientLight Color="#909090"/>
                </ModelVisual3D.Content>
            </ModelVisual3D>

            <ModelVisual3D>
                <ModelVisual3D.Content>
                    <DirectionalLight Color="#C0C0C8" Direction="-1,-2,-1"/>
                </ModelVisual3D.Content>
            </ModelVisual3D>

            <!-- Result mesh: colormap via TextureCoordinates + LinearGradientBrush material -->
            <ModelVisual3D x:Name="ResultModelVisual"
                           Content="{Binding ResultModel}"/>

        </helix:HelixViewport3D>

        <!-- Color legend overlay (on viewport row) -->
        <Border Grid.Row="1"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="8"
                Background="#CC000000"
                CornerRadius="4"
                Padding="8">
            <StackPanel>
                <TextBlock Text="{Binding MaxLabel}" Foreground="Red" FontSize="11"/>
                <Rectangle Width="20" Height="100">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="Red"    Offset="0"/>
                            <GradientStop Color="Yellow" Offset="0.25"/>
                            <GradientStop Color="Green"  Offset="0.50"/>
                            <GradientStop Color="Cyan"   Offset="0.75"/>
                            <GradientStop Color="Blue"   Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <TextBlock Text="{Binding MinLabel}" Foreground="Blue" FontSize="11"/>
            </StackPanel>
        </Border>

        <!-- Render-guard warning banner -->
        <Border Grid.Row="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="8"
                Background="#CC7A3000"
                BorderBrush="#FFAA00"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10,6"
                MaxWidth="640"
                Visibility="{Binding RenderError,
                    Converter={StaticResource NullToVisibilityConverter}}">
            <TextBlock Text="{Binding RenderError}"
                       Foreground="#FFDD88"
                       FontFamily="Consolas"
                       FontSize="11"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- Node probe tooltip -->
        <Border Grid.Row="1"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Margin="8"
                Background="#AA000000"
                CornerRadius="4"
                Padding="8"
                Visibility="{Binding ProbeText,
                    Converter={StaticResource NullToVisibilityConverter}}">
            <TextBlock Text="{Binding ProbeText}"
                       Foreground="White"
                       FontFamily="Consolas"
                       FontSize="11"/>
        </Border>

        <!-- ── Bottom controls ── -->
        <DockPanel Grid.Row="2"
                   Background="{StaticResource SurfaceBrush}"
                   LastChildFill="True">

            <ComboBox DockPanel.Dock="Left"
                      Width="160"
                      Margin="4"
                      SelectedItem="{Binding DisplayMode}">
                <vm:ResultDisplayMode>VonMises</vm:ResultDisplayMode>
                <vm:ResultDisplayMode>MaxPrincipal</vm:ResultDisplayMode>
                <vm:ResultDisplayMode>MinPrincipal</vm:ResultDisplayMode>
                <vm:ResultDisplayMode>DisplacementMag</vm:ResultDisplayMode>
                <vm:ResultDisplayMode>DisplacementX</vm:ResultDisplayMode>
                <vm:ResultDisplayMode>DisplacementY</vm:ResultDisplayMode>
                <vm:ResultDisplayMode>DisplacementZ</vm:ResultDisplayMode>
                <vm:ResultDisplayMode>StrainVonMises</vm:ResultDisplayMode>
                <vm:ResultDisplayMode>StrainXX</vm:ResultDisplayMode>
                <vm:ResultDisplayMode>StrainYY</vm:ResultDisplayMode>
                <vm:ResultDisplayMode>StrainZZ</vm:ResultDisplayMode>
            </ComboBox>

            <CheckBox DockPanel.Dock="Left"
                      Content="Deformed"
                      Margin="4"
                      VerticalAlignment="Center"
                      Foreground="{StaticResource TextBrush}"
                      ToolTip="When unchecked, stress/strain render on undeformed geometry."
                      IsChecked="{Binding RenderOnDeformedGeometry}"/>
            <CheckBox DockPanel.Dock="Left"
                      Content="Auto-scale"
                      Margin="4"
                      VerticalAlignment="Center"
                      Foreground="{StaticResource TextBrush}"
                      IsChecked="{Binding AutoDeformationScale}"/>
            <Label DockPanel.Dock="Left"
                   Content="Scale:"
                   VerticalAlignment="Center"
                   Foreground="{StaticResource TextBrush}"/>
            <Slider DockPanel.Dock="Left"
                    Width="120"
                    Minimum="0"
                    Maximum="100"
                    Value="{Binding DeformationScale}"
                    VerticalAlignment="Center"
                    Margin="4"/>
            <TextBlock DockPanel.Dock="Left"
                       Text="{Binding DeformationScale, StringFormat={}{0:F0}×}"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource MutedTextBrush}"
                       Margin="4,0"/>

            <TextBlock Text="{Binding SurfaceDiagnostic}"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right"
                       Foreground="{StaticResource MutedTextBrush}"
                       FontFamily="Consolas"
                       FontSize="10"
                       Margin="8,0"/>
        </DockPanel>
    </Grid>
</UserControl>
