<UserControl x:Class="FEASolver.Views.PropertiesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:FEASolver.ViewModels"
             xmlns:models="clr-namespace:FEASolver.Core.Models;assembly=FEASolver.Core">

    <DockPanel Background="{StaticResource SurfaceBrush}">

        <TextBlock DockPanel.Dock="Top"
                   Text="Properties"
                   Padding="8,6"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource TextBrush}"
                   Background="{StaticResource PrimaryBrush}"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="8">

                <!-- ── Material ──────────────────────────────── -->
                <Expander Header="Material" IsExpanded="True"
                          Foreground="{StaticResource TextBrush}">
                    <Grid Margin="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Label Grid.Row="0" Grid.Column="0" Content="Name"/>
                        <TextBox Grid.Row="0" Grid.Column="1"
                                 Text="{Binding CurrentMaterial.Name}"/>
                        <Label Grid.Row="1" Grid.Column="0" Content="E (GPa)"/>
                        <TextBox Grid.Row="1" Grid.Column="1"
                                 Text="{Binding YoungsModulusGPa,
                                     StringFormat={}{0:G6},
                                     UpdateSourceTrigger=LostFocus}"/>
                        <Label Grid.Row="2" Grid.Column="0" Content="ν"/>
                        <TextBox Grid.Row="2" Grid.Column="1"
                                 Text="{Binding CurrentMaterial.PoissonsRatio}"/>
                    </Grid>
                </Expander>

                <Separator Margin="0,6"/>

                <!-- ── Boundary Conditions ───────────────────── -->
                <Expander Header="Boundary Conditions" IsExpanded="True"
                          Foreground="{StaticResource TextBrush}">
                    <StackPanel Margin="4">
                        <ComboBox SelectedItem="{Binding SelectedBcType}"
                                  Margin="0,2">
                            <models:BcType>Fixed</models:BcType>
                            <models:BcType>Pinned</models:BcType>
                            <models:BcType>RollerX</models:BcType>
                            <models:BcType>RollerY</models:BcType>
                            <models:BcType>RollerZ</models:BcType>
                        </ComboBox>
                        <Button Content="Assign BC to Selected Faces"
                                Command="{Binding AssignBoundaryConditionCommand}"
                                Margin="0,4"/>
                        <ListBox ItemsSource="{Binding BoundaryConditions}"
                                 MaxHeight="120"
                                 Background="{StaticResource PrimaryBrush}"
                                 Foreground="{StaticResource TextBrush}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel>
                                        <Button DockPanel.Dock="Right"
                                                Content="✕"
                                                Command="{Binding DataContext.RemoveSelectedCommand,
                                                    RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent"
                                                Foreground="#C0392B"
                                                BorderThickness="0"
                                                Width="18" Height="18"
                                                Padding="0"
                                                Margin="4,0,0,0"/>
                                        <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                                    </DockPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Expander>

                <Separator Margin="0,6"/>

                <!-- ── Loads ──────────────────────────────────── -->
                <Expander Header="Loads" IsExpanded="True"
                          Foreground="{StaticResource TextBrush}">
                    <StackPanel Margin="4">

                        <!-- Load type selector (Moment removed — use Torque) -->
                        <ComboBox SelectedItem="{Binding SelectedLoadType}"
                                  Margin="0,2">
                            <models:LoadType>DistributedForce</models:LoadType>
                            <models:LoadType>SurfaceTraction</models:LoadType>
                            <models:LoadType>Pressure</models:LoadType>
                            <models:LoadType>PointLoad</models:LoadType>
                            <models:LoadType>Torque</models:LoadType>
                        </ComboBox>

                        <!-- Magnitude -->
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Label Content="{Binding LoadMagnitudeLabel}"
                                   ToolTip="DistributedForce / PointLoad: total N · Pressure / SurfaceTraction: MPa · Torque: N·m"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding LoadMagnitude}"/>
                        </Grid>

                        <!-- Direction (for traction/distributed — hidden for Torque) -->
                        <StackPanel Orientation="Horizontal" Margin="0,2"
                                    Visibility="{Binding IsTorqueSelected,
                                        Converter={StaticResource InverseBoolToVisibilityConverter}}">
                            <Label Content="Dir X"/>
                            <TextBox Width="40" Text="{Binding LoadDirX}"/>
                            <Label Content="Y"/>
                            <TextBox Width="40" Text="{Binding LoadDirY}"/>
                            <Label Content="Z"/>
                            <TextBox Width="40" Text="{Binding LoadDirZ}"/>
                        </StackPanel>

                        <!-- ── Torque axis panel (visible only when Torque is selected) -->
                        <StackPanel Margin="0,4"
                                    Visibility="{Binding IsTorqueSelected,
                                        Converter={StaticResource BoolToVisibilityConverter}}">

                            <Label Content="Torque Axis:" Padding="0,2,0,0"/>

                            <ComboBox SelectedItem="{Binding SelectedTorqueAxisMode}"
                                      Margin="0,2"
                                      ToolTip="Choose how the rotation axis is defined">
                                <vm:TorqueAxisMode>GlobalX</vm:TorqueAxisMode>
                                <vm:TorqueAxisMode>GlobalY</vm:TorqueAxisMode>
                                <vm:TorqueAxisMode>GlobalZ</vm:TorqueAxisMode>
                                <vm:TorqueAxisMode>FaceNormal</vm:TorqueAxisMode>
                                <vm:TorqueAxisMode>Custom</vm:TorqueAxisMode>
                            </ComboBox>

                            <!-- Custom axis fields — visible only in Custom mode -->
                            <StackPanel Orientation="Horizontal" Margin="0,2"
                                        Visibility="{Binding IsCustomTorqueAxis,
                                            Converter={StaticResource BoolToVisibilityConverter}}">
                                <Label Content="X"/>
                                <TextBox Width="38"
                                         Text="{Binding MomentAxisX,
                                             UpdateSourceTrigger=PropertyChanged}"/>
                                <Label Content="Y"/>
                                <TextBox Width="38"
                                         Text="{Binding MomentAxisY,
                                             UpdateSourceTrigger=PropertyChanged}"/>
                                <Label Content="Z"/>
                                <TextBox Width="38"
                                         Text="{Binding MomentAxisZ,
                                             UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <!-- Axis summary / status line -->
                            <TextBlock Text="{Binding TorqueAxisSummary}"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="10"
                                       Margin="0,2"
                                       TextWrapping="Wrap"/>

                        </StackPanel>

                        <Button Content="Assign Load to Selected Faces"
                                Command="{Binding AssignLoadCommand}"
                                Margin="0,4"/>

                        <ListBox ItemsSource="{Binding Loads}"
                                 MaxHeight="120"
                                 Background="{StaticResource PrimaryBrush}"
                                 Foreground="{StaticResource TextBrush}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel>
                                        <Button DockPanel.Dock="Right"
                                                Content="✕"
                                                Command="{Binding DataContext.RemoveSelectedCommand,
                                                    RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent"
                                                Foreground="#C0392B"
                                                BorderThickness="0"
                                                Width="18" Height="18"
                                                Padding="0"
                                                Margin="4,0,0,0"/>
                                        <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                                    </DockPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Expander>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
