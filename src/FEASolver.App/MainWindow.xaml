<Window x:Class="FEASolver.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:FEASolver.ViewModels"
        xmlns:views="clr-namespace:FEASolver.Views"
        mc:Ignorable="d"
        Title="FEA Solver" Height="900" Width="1400"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource PrimaryBrush}">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <DockPanel>

        <!-- ── Menu bar ── -->
        <Menu DockPanel.Dock="Top" Background="{StaticResource SurfaceBrush}"
              Foreground="{StaticResource TextBrush}">
            <MenuItem Header="_File">
                <MenuItem Header="_New Model..."
                          Command="{Binding NewModelCommand}"
                          ToolTip="Clear everything and import a new STEP file"/>
                <MenuItem Header="_Import STEP..." Command="{Binding ImportStepCommand}"/>
                <MenuItem Header="Reset _Loads..."
                          Command="{Binding ResetLoadsCommand}"
                          ToolTip="Clear boundary conditions and loads (keep mesh)"/>
                <Separator/>
                <MenuItem Header="Export Results CSV..."
                          Command="{Binding ExportResultsCommand}"
                          IsEnabled="{Binding HasResults}"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="MenuExit_Click"/>
            </MenuItem>
            <MenuItem Header="_Analysis">
                <MenuItem Header="_Mesh" Command="{Binding MeshCommand}"/>
                <MenuItem Header="_Run Solver" Command="{Binding RunSolverCommand}"/>
                <Separator/>
                <MenuItem Header="_Cancel" Command="{Binding CancelCommand}"
                          Visibility="{Binding CancelVisible}"/>
            </MenuItem>
            <MenuItem Header="_Tools">
                <MenuItem Header="_Configuration..." Command="{Binding OpenConfigCommand}"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About" Command="{Binding AboutCommand}"/>
            </MenuItem>
        </Menu>

        <!-- ── Toolbar ── -->
        <ToolBar DockPanel.Dock="Top" Background="{StaticResource SurfaceBrush}">
            <Button Content="⊞ New Model" Command="{Binding NewModelCommand}" Margin="2"
                    ToolTip="Clear everything and import a new STEP file"/>
            <Button Content="Import STEP" Command="{Binding ImportStepCommand}" Margin="2"/>
            <Separator/>
            <!-- "Edit Model" button: always visible, navigates back to Geometry tab -->
            <Button Content="◀ Edit Model"
                    Command="{Binding GoToGeometryCommand}"
                    Margin="2"
                    ToolTip="Go back to the Geometry tab to edit loads and boundary conditions"
                    Background="#3A5A3A"
                    Foreground="White"/>
            <Button Content="↺ Reset Loads"
                    Command="{Binding ResetLoadsCommand}"
                    Margin="2"
                    ToolTip="Clear boundary conditions and loads (keeps mesh)"
                    Background="#5A3A3A"
                    Foreground="White"/>
            <Separator/>
            <Button Content="Mesh" Command="{Binding MeshCommand}" Margin="2"/>
            <TextBlock Text="Size:" VerticalAlignment="Center" Margin="4,0,2,0"/>
            <TextBox Width="48"
                     Text="{Binding MeshElementSizeMm, StringFormat={}{0:G4}, UpdateSourceTrigger=LostFocus}"
                     VerticalAlignment="Center"
                     Padding="2,1"
                     Background="#2A2A3E"
                     Foreground="#E0E0E0"
                     BorderBrush="#444466"
                     ToolTip="Element size (in source STEP units)"/>
            <TextBlock Text="STEP units:" VerticalAlignment="Center" Margin="6,0,2,0"/>
            <ComboBox Width="60"
                      VerticalAlignment="Center"
                      SelectedValue="{Binding StepInputUnits, UpdateSourceTrigger=PropertyChanged}"
                      SelectedValuePath="Content"
                      Background="#2A2A3E"
                      Foreground="#E0E0E0"
                      BorderBrush="#444466"
                      ToolTip="Length unit of the source STEP file. Wrong choice produces ~10^6× stress errors.">
                <ComboBoxItem Content="mm"/>
                <ComboBoxItem Content="m"/>
            </ComboBox>
            <Button Content="Run Solver" Command="{Binding RunSolverCommand}" Margin="2"/>
            <Separator/>
            <Button Content="Export CSV"
                    Command="{Binding ExportResultsCommand}"
                    Margin="2"/>
            <Separator/>
            <!-- Cancel — only visible during long ops -->
            <Button Content="■ Cancel"
                    Command="{Binding CancelCommand}"
                    Visibility="{Binding CancelVisible}"
                    Background="#C0392B"
                    Margin="2"/>
            <Separator/>
            <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center"
                       Foreground="{StaticResource MutedTextBrush}" Margin="6,0"/>
        </ToolBar>

        <!-- ── Status bar ── -->
        <StatusBar DockPanel.Dock="Bottom" Background="{StaticResource SurfaceBrush}"
                   Foreground="{StaticResource TextBrush}">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding MeshStats}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem HorizontalAlignment="Right">
                <ProgressBar Width="120" Height="14"
                             Value="{Binding Progress}"
                             Visibility="{Binding ProgressVisible}"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ── Error detail panel (docked above status bar) ── -->
        <Border DockPanel.Dock="Bottom"
                Background="#1A0000"
                BorderBrush="#C0392B"
                BorderThickness="0,1,0,0"
                Visibility="{Binding ErrorPanelVisible}">
            <DockPanel Margin="4,2">
                <Button DockPanel.Dock="Right"
                        Content="✕"
                        Command="{Binding DismissErrorCommand}"
                        Background="Transparent"
                        Foreground="#C0392B"
                        BorderThickness="0"
                        Width="22" Height="22"
                        VerticalAlignment="Top"
                        Margin="4,0,0,0"/>
                <TextBlock DockPanel.Dock="Left"
                           Text="Error  "
                           Foreground="#E74C3C"
                           FontWeight="Bold"
                           VerticalAlignment="Top"
                           Margin="0,2"/>
                <ScrollViewer MaxHeight="80"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <TextBlock Text="{Binding LastErrorDetail}"
                               Foreground="#FFAAAA"
                               FontFamily="Consolas"
                               FontSize="11"
                               TextWrapping="Wrap"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ── Main layout: tree | viewport | properties ── -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="150"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*" MinWidth="300"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="260" MinWidth="180"/>
            </Grid.ColumnDefinitions>

            <views:ModelTreeView Grid.Column="0"
                                 DataContext="{Binding ModelTree}"/>

            <GridSplitter Grid.Column="1" Width="5"
                          HorizontalAlignment="Stretch"
                          Background="{StaticResource SurfaceBrush}"/>

            <TabControl Grid.Column="2"
                        Background="{StaticResource PrimaryBrush}"
                        BorderThickness="0"
                        SelectedIndex="{Binding SelectedTabIndex}">
                <TabItem Header="Geometry">
                    <views:ViewportView DataContext="{Binding Viewport}"/>
                </TabItem>
                <TabItem Header="Results"
                         IsEnabled="{Binding HasResults}">
                    <views:ResultsView DataContext="{Binding Results}"/>
                </TabItem>
            </TabControl>

            <GridSplitter Grid.Column="3" Width="5"
                          HorizontalAlignment="Stretch"
                          Background="{StaticResource SurfaceBrush}"/>

            <views:PropertiesView Grid.Column="4"
                                  DataContext="{Binding Properties}"/>
        </Grid>

    </DockPanel>
</Window>
